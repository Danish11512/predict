# Copy to .env and fill in. Never commit .env.
#
# development — local defaults; run.sh frees pinned ports before/after dev.
# production — run.sh skips port killing (safe on shared hosts); use real deploy for prod.
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Docs: https://docs.kalshi.com/getting_started/api_keys
#       https://docs.kalshi.com/getting_started/quick_start_authenticated_requests
#       https://docs.kalshi.com/getting_started/quick_start_websockets

# Key ID from Kalshi Account → API Keys (production)
KALSHI_API_KEY_ID=

# PEM text of your RSA private key. In .env, use \n for line breaks, e.g.
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
KALSHI_PRIVATE_KEY_PEM=

# Production REST API base (path prefix /trade-api/v2 included)
KALSHI_REST_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Production WebSocket URL
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2

# Optional: only if the browser calls this API directly (not via Vite /api proxy).
# Comma-separated list, e.g. http://localhost:5173,http://127.0.0.1:5173
# CORS_ALLOWED_ORIGINS=
