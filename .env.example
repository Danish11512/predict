# =============================================================================
# Kalshi website (external) — URL Selenium opens in the browser.
# This is NOT the Predict FastAPI server. Required for scraping/login flows.
# Prefer KALSHI_PUBLIC_URL. BASE_URL is a legacy alias (same meaning) if unset.
# =============================================================================
KALSHI_PUBLIC_URL=https://kalshi.com
# BASE_URL=https://kalshi.com

# Backend auth (Kalshi account)
KALSHI_EMAIL=
KALSHI_PASSWORD=

# =============================================================================
# This repository's FastAPI backend (local process)
# PORT = HTTP listen port for uvicorn (GET /live-games, GET /stream, etc.)
# =============================================================================
PORT=8000

# =============================================================================
# Frontend → this repo's API (NOT Kalshi)
# Browser / SvelteKit use this to call the FastAPI server (sse + REST).
# =============================================================================
PUBLIC_API_BASE_URL=http://localhost:8000

# Backend runtime (scraping / driver tuning — unrelated to URLs above except ENV)
ENV=dev
IS_CONTAINER=false
LATENCY_MS=0
VERIFY_WAIT_TIMEOUT=120
LIVE_GAMES_POLL_SEC=5

# Frontend dev server port only (Vite); not the API origin
FRONTEND_PORT=5173
